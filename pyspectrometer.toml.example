[camera]
frame_width = 1280
frame_height = 720
gain = 10.0
fps = 30
monochrome = true
bit_depth = 10

[display]
fullscreen = false
waterfall_enabled = false
# Layout: graph + preview + message = stack_height. Pixel-perfect, no scaling.
graph_height = 280
preview_height = 60
message_height = 60
window_width = 640
font_scale = 0.35
text_thickness = 1
graph_label_font = 1
graph_label_font_scale = 0.9
status_col1_x = 340
status_col2_x = 500

[calibration]
cal_pixels = [
    0,
    320,
    640,
    960,
    1279,
]
cal_wavelengths = [
    380.0,
    472.57232212666145,
    565.1446442533229,
    657.7169663799843,
    750.0,
]
rotation_angle = 6.042216729687787
spectrum_y_center = 420
perpendicular_width = 20
default_pixels = [
    0,
    640,
    1280,
]
default_wavelengths = [
    380.0,
    560.0,
    750.0,
]

[processing]
savgol_window = 17
savgol_poly = 7
peak_min_distance = 5
peak_threshold = 10
peak_max_count = 10
peak_include_region_half_width = 25
pixel_rows_to_average = 3

[export]
output_dir = "."
timestamp_format = "%Y%m%d--%H%M%S"
time_format = "%H:%M:%S"

[waterfall]
contrast = 2.5
brightness = 10

[extraction]
method = "weighted_sum"
rotation_angle = 0.0
perpendicular_width = 20
spectrum_y_center = 0
background_percentile = 10.0
